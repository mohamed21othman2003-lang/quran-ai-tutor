# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# ChromaDB — MUST be absolute path on Railway Volume
CHROMA_PERSIST_DIR=/data/chroma_db

# Knowledge base (Tajweed RAG source files)
KNOWLEDGE_DIR=data/knowledge

# Retrieval
TOP_K=3

# Logging
LOG_LEVEL=INFO

# Auth (JWT)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# Admin
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Database — MUST be absolute path on Railway Volume
DB_PATH=/data/quran_tutor.db

# Tafsir DB — MUST be absolute path on Railway Volume
TAFSIR_DB_DIR=/data/tafsir

# NOTE: Do NOT add TAFSIR_CHROMA_DIR — it is intentionally ignored in src/tafsir/store.py
# The tafsir FAISS index path is hardcoded to /data/tafsir_faiss/ in src/config.py
